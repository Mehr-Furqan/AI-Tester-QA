# ── Jira (only needed if you push tickets to Jira) ────────────────────────────
# Your Atlassian account email
JIRA_EMAIL=you@yourcompany.com

# API token — create one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your_jira_api_token_here

# Your Jira instance URL (no trailing slash)
JIRA_URL=https://yourcompany.atlassian.net

# Project key — the prefix on your tickets e.g. "QA" or "BUG"
JIRA_PROJECT_KEY=QA

# ── Optional ──────────────────────────────────────────────────────────────────
# Jira user account ID to auto-assign tickets (get from Jira profile URL)
# JIRA_ASSIGNEE_ID=

# Override default model
# OLLAMA_MODEL=qwen2.5:7b
